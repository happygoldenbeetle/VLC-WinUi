<Page x:Class="WinUIVLC.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:helpers="using:WinUIVLC.Helpers"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:xaml="using:Microsoft.UI.Xaml"
      mc:Ignorable="d">
    <Page.Resources>
        <helpers:EnumToBooleanConverter x:Key="EnumToBooleanConverter" />
    </Page.Resources>
    <Grid Margin="{StaticResource NavigationViewPageContentMargin}">
        <ScrollViewer HorizontalScrollMode="Disabled"
                      VerticalScrollBarVisibility="Auto"
                      VerticalScrollMode="Auto">
            <StackPanel x:Name="ContentArea" Padding="0,0,0,24">
                <TextBlock x:Uid="Settings_Personalization" Style="{ThemeResource SubtitleTextBlockStyle}" />
                <StackPanel Margin="{StaticResource SmallTopBottomMargin}">
                    <TextBlock x:Uid="Settings_Theme" />

                    <StackPanel Margin="{StaticResource XSmallTopMargin}">
                        <RadioButton x:Uid="Settings_Theme_Light"
                                     Command="{x:Bind ViewModel.SwitchThemeCommand}"
                                     FontSize="15"
                                     GroupName="AppTheme"
                                     IsChecked="{x:Bind ViewModel.ElementTheme, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Light, Mode=OneWay}">
                            <RadioButton.CommandParameter>
                                <xaml:ElementTheme>Light</xaml:ElementTheme>
                            </RadioButton.CommandParameter>
                        </RadioButton>
                        <RadioButton x:Uid="Settings_Theme_Dark"
                                     Command="{x:Bind ViewModel.SwitchThemeCommand}"
                                     FontSize="15"
                                     GroupName="AppTheme"
                                     IsChecked="{x:Bind ViewModel.ElementTheme, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Dark, Mode=OneWay}">
                            <RadioButton.CommandParameter>
                                <xaml:ElementTheme>Dark</xaml:ElementTheme>
                            </RadioButton.CommandParameter>
                        </RadioButton>
                        <RadioButton x:Uid="Settings_Theme_Default"
                                     Command="{x:Bind ViewModel.SwitchThemeCommand}"
                                     FontSize="15"
                                     GroupName="AppTheme"
                                     IsChecked="{x:Bind ViewModel.ElementTheme, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Default, Mode=OneWay}">
                            <RadioButton.CommandParameter>
                                <xaml:ElementTheme>Default</xaml:ElementTheme>
                            </RadioButton.CommandParameter>
                        </RadioButton>
                    </StackPanel>
                </StackPanel>

                <TextBlock Margin="{StaticResource SmallTopBottomMargin}"
                           Style="{ThemeResource SubtitleTextBlockStyle}"
                           Text="Playback" />
                <StackPanel Margin="{StaticResource XSmallTopMargin}" Spacing="14">
                    <ToggleSwitch Header="Resume from where you left off" IsOn="{x:Bind ViewModel.ResumePlayback, Mode=TwoWay}" />

                    <StackPanel>
                        <Grid Width="360" HorizontalAlignment="Left">
                            <TextBlock HorizontalAlignment="Left" Text="Default volume" />
                            <TextBlock HorizontalAlignment="Right"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Text="{x:Bind ViewModel.DefaultVolume, Mode=OneWay}" />
                        </Grid>
                        <Slider Width="360"
                                HorizontalAlignment="Left"
                                Maximum="100"
                                Minimum="0"
                                SnapsTo="StepValues"
                                StepFrequency="5"
                                TickFrequency="10"
                                TickPlacement="Outside"
                                Value="{x:Bind ViewModel.DefaultVolume, Mode=TwoWay}" />
                    </StackPanel>

                    <StackPanel>
                        <Grid Width="360" HorizontalAlignment="Left">
                            <TextBlock HorizontalAlignment="Left" Text="Default playback speed" />
                            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind ViewModel.DefaultPlaybackSpeed, Mode=OneWay}" />
                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="×" />
                            </StackPanel>
                        </Grid>
                        <Slider Width="360"
                                HorizontalAlignment="Left"
                                Maximum="2"
                                Minimum="0.5"
                                SnapsTo="StepValues"
                                StepFrequency="0.25"
                                TickFrequency="0.25"
                                TickPlacement="Outside"
                                Value="{x:Bind ViewModel.DefaultPlaybackSpeed, Mode=TwoWay}" />
                    </StackPanel>

                    <StackPanel>
                        <Grid Width="360" HorizontalAlignment="Left">
                            <TextBlock HorizontalAlignment="Left" Text="Hide controls when idle" />
                            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind ViewModel.AutoHideDelaySeconds, Mode=OneWay}" />
                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text=" s" />
                            </StackPanel>
                        </Grid>
                        <Slider Width="360"
                                HorizontalAlignment="Left"
                                Maximum="10"
                                Minimum="1"
                                SnapsTo="StepValues"
                                StepFrequency="1"
                                TickFrequency="1"
                                TickPlacement="Outside"
                                Value="{x:Bind ViewModel.AutoHideDelaySeconds, Mode=TwoWay}" />
                    </StackPanel>

                    <StackPanel>
                        <Grid Width="360" HorizontalAlignment="Left">
                            <TextBlock HorizontalAlignment="Left" Text="Short skip" />
                            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind ViewModel.SeekShortSeconds, Mode=OneWay}" />
                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text=" s" />
                            </StackPanel>
                        </Grid>
                        <Slider Width="360"
                                HorizontalAlignment="Left"
                                Maximum="30"
                                Minimum="1"
                                SnapsTo="StepValues"
                                StepFrequency="1"
                                TickFrequency="5"
                                TickPlacement="Outside"
                                Value="{x:Bind ViewModel.SeekShortSeconds, Mode=TwoWay}" />
                    </StackPanel>

                    <StackPanel>
                        <Grid Width="360" HorizontalAlignment="Left">
                            <TextBlock HorizontalAlignment="Left" Text="Normal skip" />
                            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind ViewModel.SeekNormalSeconds, Mode=OneWay}" />
                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text=" s" />
                            </StackPanel>
                        </Grid>
                        <Slider Width="360"
                                HorizontalAlignment="Left"
                                Maximum="60"
                                Minimum="5"
                                SnapsTo="StepValues"
                                StepFrequency="5"
                                TickFrequency="5"
                                TickPlacement="Outside"
                                Value="{x:Bind ViewModel.SeekNormalSeconds, Mode=TwoWay}" />
                    </StackPanel>

                    <StackPanel>
                        <Grid Width="360" HorizontalAlignment="Left">
                            <TextBlock HorizontalAlignment="Left" Text="Long skip" />
                            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind ViewModel.SeekLongSeconds, Mode=OneWay}" />
                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text=" s" />
                            </StackPanel>
                        </Grid>
                        <Slider Width="360"
                                HorizontalAlignment="Left"
                                Maximum="300"
                                Minimum="30"
                                SnapsTo="StepValues"
                                StepFrequency="10"
                                TickFrequency="30"
                                TickPlacement="Outside"
                                Value="{x:Bind ViewModel.SeekLongSeconds, Mode=TwoWay}" />
                    </StackPanel>
                </StackPanel>

                <TextBlock Margin="{StaticResource SmallTopBottomMargin}"
                           Style="{ThemeResource SubtitleTextBlockStyle}"
                           Text="Subtitles &amp; audio" />
                <StackPanel Margin="{StaticResource XSmallTopMargin}" Spacing="14">
                    <ToggleSwitch Header="Show subtitles by default" IsOn="{x:Bind ViewModel.SubtitlesEnabledByDefault, Mode=TwoWay}" />
                    <ComboBox Width="280"
                              Header="Preferred subtitle language"
                              ItemsSource="{x:Bind ViewModel.Languages}"
                              SelectedItem="{x:Bind ViewModel.PreferredSubtitleLanguage, Mode=TwoWay}" />

                    <StackPanel>
                        <Grid Width="360" HorizontalAlignment="Left">
                            <TextBlock HorizontalAlignment="Left" Text="Subtitle font scale" />
                            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind ViewModel.SubtitleFontScale, Mode=OneWay}" />
                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text=" %" />
                            </StackPanel>
                        </Grid>
                        <Slider Width="360"
                                HorizontalAlignment="Left"
                                Maximum="300"
                                Minimum="50"
                                SnapsTo="StepValues"
                                StepFrequency="10"
                                TickFrequency="50"
                                TickPlacement="Outside"
                                Value="{x:Bind ViewModel.SubtitleFontScale, Mode=TwoWay}" />
                    </StackPanel>

                    <ComboBox Width="280"
                              Header="Preferred audio language"
                              ItemsSource="{x:Bind ViewModel.Languages}"
                              SelectedItem="{x:Bind ViewModel.PreferredAudioLanguage, Mode=TwoWay}" />
                </StackPanel>

                <TextBlock x:Uid="Settings_About" Style="{ThemeResource SubtitleTextBlockStyle}" />

                <StackPanel Margin="{StaticResource XSmallTopMargin}">
                    <TextBlock Style="{ThemeResource BodyTextBlockStyle}" Text="{x:Bind ViewModel.VersionDescription, Mode=OneWay}" />

                    <TextBlock x:Uid="Settings_AboutDescription"
                               Margin="{StaticResource XSmallTopMargin}"
                               Style="{ThemeResource BodyTextBlockStyle}" />
                    <HyperlinkButton x:Uid="SettingsPage_PrivacyTermsLink" Margin="{StaticResource SettingsPageHyperlinkButtonMargin}" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
