<Page x:Class="WinUIVLC.Views.PlaylistPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:vm="using:WinUIVLC.ViewModels"
      mc:Ignorable="d">

    <Grid Margin="{StaticResource NavigationViewPageContentMargin}" RowSpacing="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Load a playlist  -->
        <Grid Grid.Row="0" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox PlaceholderText="M3U playlist URL (http://…/playlist.m3u)" Text="{x:Bind ViewModel.M3uUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <Button Grid.Column="1"
                    Command="{x:Bind ViewModel.LoadFromUrlCommand}"
                    Content="Load"
                    Style="{ThemeResource AccentButtonStyle}" />
            <Button Grid.Column="2"
                    Command="{x:Bind ViewModel.LoadFromFileCommand}"
                    Content="Open .m3u file" />
        </Grid>

        <!--  Search + status  -->
        <TextBox Grid.Row="1"
                 PlaceholderText="Search channels…"
                 Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8">
            <ProgressRing Width="16"
                          Height="16"
                          IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" />
            <TextBlock VerticalAlignment="Center"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Text="{x:Bind ViewModel.Status, Mode=OneWay}" />
        </StackPanel>

        <ListView Grid.Row="3"
                  ItemClick="OnItemClick"
                  IsItemClickEnabled="True"
                  ItemsSource="{x:Bind ViewModel.Channels, Mode=OneWay}"
                  SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:PlaylistItem">
                    <Grid Padding="0,6" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{x:Bind Title}" TextTrimming="CharacterEllipsis" />
                            <TextBlock FontSize="11"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Text="{x:Bind Group}"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <FontIcon Grid.Column="1"
                                  FontSize="14"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                  Glyph="&#xE768;" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
